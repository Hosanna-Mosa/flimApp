{
  "expo": {
    "name": "FilmyConnect",
    "slug": "filmy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "splash": {
      "image": "./assets/images/splash_new.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.rork.filmy",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "FilmyConnect uses your photo library to let you upload profile pictures, portfolio images, and media content to showcase your work to the film industry community.",
        "NSCameraUsageDescription": "FilmyConnect uses your camera to capture photos and videos for your portfolio, profile picture, and content uploads to share with the film industry community.",
        "NSMicrophoneUsageDescription": "FilmyConnect uses your microphone to record audio while capturing videos for your portfolio and content uploads on the platform."
      }
    },
    "android": {
      "package": "app.rork.filmy",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon_new.jpeg",
        "backgroundColor": "#000000"
      },
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.VIBRATE",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "notification": {
      "icon": "./assets/images/icon.png",
      "color": "#ffffff"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.jpeg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-navigation-bar",
        {
          "position": "absolute",
          "visibility": "visible",
          "behavior": "inset-swipe",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "FilmyConnect uses your photo library to let you upload profile pictures, portfolio images, and media content to showcase your work to the film industry community.",
          "savePhotosPermission": "Allow FilmyConnect to save photos and media to your library.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "react-native-iap"
    ],
    "extra": {
      "apiUrl": "https://api.filmyconnect24.com",
      "router": {},
      "expo-navigation-bar": {
        "position": "absolute",
        "visibility": "visible",
        "behavior": "inset-swipe",
        "backgroundColor": "#000000"
      },
      "eas": {
        "projectId": "78bb7239-da5e-467f-919f-e285dbfbd9fa"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "owner": "hosanna4189"
  }
}